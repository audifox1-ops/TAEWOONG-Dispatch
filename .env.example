# ============================================
# 배차지시서 통합 관리 시스템 - 환경변수 설정
# .env.example을 복사해서 .env로 사용하세요
# cp .env.example .env
# ============================================

# ---- PostgreSQL 데이터베이스 ----
POSTGRES_DB=dispatch_db
POSTGRES_USER=dispatch_user
POSTGRES_PASSWORD=dispatch_pass_change_me
POSTGRES_PORT=5432

# ---- Prisma 연결 URL ----
DATABASE_URL=postgresql://dispatch_user:dispatch_pass_change_me@localhost:5432/dispatch_db

# ---- JWT 인증 ----
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_at_least_32_chars_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- 서버 포트 ----
API_PORT=3000
WEB_PORT=5173

# ---- 환경 ----
NODE_ENV=development

# ---- 프론트엔드 API URL ----
VITE_API_BASE_URL=http://localhost:3000
